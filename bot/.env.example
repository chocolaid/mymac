# ── Telegram ──────────────────────────────────────────────────────────────────
# Get from @BotFather
TELEGRAM_TOKEN=123456789:AABBCCDDyourTokenHere

# Your personal Telegram chat ID — message @userinfobot to find it
ALLOWED_CHAT_ID=987654321

# ── Secrets ───────────────────────────────────────────────────────────────────
# Shared with Mac agents — must match AGENT_SECRET baked into the binary
# Generate: openssl rand -hex 32
AGENT_SECRET=changeme_generate_with_openssl_rand_hex_32

# Shared with the Vercel config server
# Generate: openssl rand -hex 32
ADMIN_TOKEN=changeme_generate_with_openssl_rand_hex_32

# ── Vercel config server ──────────────────────────────────────────────────────
# URL of your deployed Vercel config server (no trailing slash)
CONFIG_SERVER_URL=https://mymac-config.vercel.app

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
