# These are set in the Vercel dashboard, NOT in this file.
# Add them at: Project → Settings → Environment Variables

# Your admin secret (generate: openssl rand -hex 32)
# Must match ADMIN_TOKEN in the bot server .env and GitHub Actions secrets
ADMIN_TOKEN=changeme_use_openssl_rand_hex_32

# These are automatically added by Vercel when you create a KV database
# (Project → Storage → Create KV Database → Link to project)
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=
